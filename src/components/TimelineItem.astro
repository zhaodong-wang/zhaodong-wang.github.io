---
interface Props {
  side: 'left' | 'right';
  from: { month: string; year: string };
  to: { month: string; year: string };
  logo?: string;
}

const { side, from, to, logo } = Astro.props;
---

<article class={`timeline-item timeline-item--${side}`} data-reveal>
  <div class="timeline-item__meta">
    <div class="timeline-item__circle">
      <span class="timeline-item__month"><em>{from.month}</em></span>
      <span class="timeline-item__year">{from.year}</span>
    </div>
    <div class="timeline-item__bar"></div>
    <div class="timeline-item__circle">
      <span class="timeline-item__month"><em>{to.month}</em></span>
      <span class="timeline-item__year">{to.year}</span>
    </div>
  </div>
  <div class="timeline-item__content">
    <slot />
  </div>
  {logo && <img class="timeline-item__logo" src={logo} alt="" aria-hidden="true" />}
</article>

<style>
  .timeline-item {
    position: relative;
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    max-width: var(--content-max);
    margin: 0 auto;
    padding: clamp(3rem, 8vh, 6rem) clamp(1rem, 5vw, 4rem);
    align-items: center;
    overflow: hidden;
  }
  .timeline-item--left {
    grid-template-columns: auto 1fr;
    text-align: left;
  }
  .timeline-item--right {
    grid-template-columns: 1fr auto;
    text-align: right;
  }
  .timeline-item--right .timeline-item__meta {
    order: 2;
  }
  .timeline-item--right .timeline-item__content {
    order: 1;
  }

  /* Circles with bar between (the "double-circles" pattern from 2015) */
  .timeline-item__meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }
  /* Circle — 80x80, two 50 percent halves. Month in the top half anchored
     to the bottom of its half; year in the bottom half anchored to the top
     of its half. Both labels sit close to the circle's horizontal midline,
     matching the 2015 .circle .half layout. */
  .timeline-item__circle {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.3);
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    overflow: hidden;
    flex-shrink: 0;
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 600ms var(--ease-smooth),
      transform 600ms var(--ease-smooth);
  }
  .timeline-item__circle > .timeline-item__month,
  .timeline-item__circle > .timeline-item__year {
    flex: 1 1 50%;
    display: flex;
    justify-content: center;
    line-height: 1;
  }
  .timeline-item__month {
    align-items: flex-end;
    padding-bottom: 4px;
    font-family: var(--font-accent);
    font-style: italic;
    color: var(--color-accent-text);
    font-size: 14px;
  }
  .timeline-item__year {
    align-items: flex-start;
    padding-top: 4px;
    font-weight: 600;
    font-size: 18px;
    color: var(--color-ink-softest);
  }
  /* Sequential choreography: from-circle appears first, bar grows, then
     to-circle appears. Matches the 2015 animateCircleTo choreography but
     compressed for a modern feel. */
  .timeline-item.is-visible .timeline-item__circle:nth-child(1) {
    opacity: 1;
    transform: scale(1);
    transition-delay: 0ms;
  }
  .timeline-item.is-visible .timeline-item__circle:nth-child(3) {
    opacity: 1;
    transform: scale(1);
    transition-delay: 700ms;
  }
  .timeline-item__bar {
    width: 1px;
    height: 38px;
    background: rgba(0, 0, 0, 0.3);
    transform-origin: top;
    transform: scaleY(0);
    transition: transform 600ms var(--ease-smooth);
  }
  .timeline-item.is-visible .timeline-item__bar {
    transform: scaleY(1);
    transition-delay: 350ms;
  }

  /* Content — text wipes in from left via clip-path when the item
     enters the viewport. Matches the 2015 copyTexts clip: rect() reveal
     that swept each line from width 0 to full width. Mine wipes per
     block (h1, h2, h3, p) with an index-based stagger, which is a
     simpler but visually similar effect. Each block animates its own
     clip-path from inset(0 100% 0 0) to inset(0 0 0 0). */
  .timeline-item__content {
    max-width: 65ch;
  }
  .timeline-item--right .timeline-item__content {
    margin-left: auto;
  }
  .timeline-item__content :global(> *) {
    clip-path: inset(0 100% 0 0);
    transition: clip-path 900ms cubic-bezier(0.6, 0, 0.4, 1);
  }
  .timeline-item.is-visible .timeline-item__content :global(> *) {
    clip-path: inset(0 0 0 0);
  }
  /* Per-block stagger — blocks are the direct children from the MD
     render, so the stagger is applied via nth-child. */
  .timeline-item.is-visible .timeline-item__content :global(> *:nth-child(1)) { transition-delay: 300ms; }
  .timeline-item.is-visible .timeline-item__content :global(> *:nth-child(2)) { transition-delay: 360ms; }
  .timeline-item.is-visible .timeline-item__content :global(> *:nth-child(3)) { transition-delay: 420ms; }
  .timeline-item.is-visible .timeline-item__content :global(> *:nth-child(4)) { transition-delay: 480ms; }
  .timeline-item.is-visible .timeline-item__content :global(> *:nth-child(5)) { transition-delay: 540ms; }
  .timeline-item.is-visible .timeline-item__content :global(> *:nth-child(6)) { transition-delay: 600ms; }
  .timeline-item.is-visible .timeline-item__content :global(> *:nth-child(7)) { transition-delay: 660ms; }
  .timeline-item.is-visible .timeline-item__content :global(> *:nth-child(8)) { transition-delay: 720ms; }
  .timeline-item--right .timeline-item__content :global(> *) {
    clip-path: inset(0 0 0 100%);
  }
  .timeline-item--right.is-visible .timeline-item__content :global(> *) {
    clip-path: inset(0 0 0 0);
  }

  .timeline-item__content :global(h1) {
    font-size: var(--text-xl);
    text-transform: uppercase;
    letter-spacing: var(--tracking-upper);
    color: var(--color-ink-soft);
    margin-bottom: 0.25em;
    font-weight: 700;
  }
  .timeline-item__content :global(h2) {
    font-family: var(--font-accent);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--color-accent);
    margin-bottom: 1em;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
  }
  .timeline-item__content :global(h3) {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: var(--tracking-upper);
    color: var(--color-ink-softest);
    margin: 1.5em 0 0.5em;
    font-weight: 500;
  }
  .timeline-item__content :global(p) {
    color: var(--color-ink-soft);
    line-height: 1.65;
    margin-bottom: 0.75em;
  }
  .timeline-item__content :global(strong) {
    color: var(--color-ink);
    font-weight: 700;
  }
  @media (prefers-reduced-motion: reduce) {
    .timeline-item__content :global(> *) {
      clip-path: none !important;
      transition: none !important;
    }
  }

  /* Background logo — floats Y as you scroll through the timeline item,
     matching the 2015 .element img.bg-logo translateY(offset * 0.3)
     scroll listener. Driven by parallax.ts on the timeline-item
     container; the logo reads --parallax-y via transform. */
  .timeline-item {
    --parallax-y: 0px;
  }
  .timeline-item__logo {
    position: absolute;
    width: 280px;
    height: auto;
    opacity: 0.08;
    pointer-events: none;
    z-index: -1;
    filter: grayscale(100%);
    transform: translateY(var(--parallax-y, 0));
  }
  .timeline-item--left .timeline-item__logo {
    right: -4rem;
    bottom: -2rem;
  }
  .timeline-item--right .timeline-item__logo {
    left: -4rem;
    top: -2rem;
  }
  @media (prefers-reduced-motion: reduce) {
    .timeline-item__logo { transform: none; }
  }

  @media (max-width: 720px) {
    .timeline-item,
    .timeline-item--left,
    .timeline-item--right {
      grid-template-columns: 1fr;
      text-align: left;
    }
    .timeline-item--right .timeline-item__meta,
    .timeline-item--right .timeline-item__content {
      order: initial;
      margin-left: 0;
    }
    .timeline-item__meta {
      flex-direction: row;
      gap: 0;
    }
    .timeline-item__bar {
      width: 60px;
      height: 1px;
      transform: scaleX(0);
      transform-origin: left;
    }
    .timeline-item.is-visible .timeline-item__bar {
      transform: scaleX(1);
    }
    .timeline-item__circle { width: 80px; height: 80px; }
    .timeline-item__logo { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .timeline-item__circle,
    .timeline-item__bar,
    .timeline-item__content {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
