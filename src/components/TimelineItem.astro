---
interface Props {
  side: 'left' | 'right';
  from: { month: string; year: string };
  to: { month: string; year: string };
  logo?: string;
}

const { side, from, to, logo } = Astro.props;
---

<article class={`timeline-item timeline-item--${side}`} data-reveal>
  <div class="timeline-item__meta">
    <div class="timeline-item__circle">
      <span class="timeline-item__month"><em>{from.month}</em></span>
      <span class="timeline-item__year">{from.year}</span>
    </div>
    <div class="timeline-item__bar"></div>
    <div class="timeline-item__circle">
      <span class="timeline-item__month"><em>{to.month}</em></span>
      <span class="timeline-item__year">{to.year}</span>
    </div>
  </div>
  <div class="timeline-item__content">
    <slot />
  </div>
  {logo && <img class="timeline-item__logo" src={logo} alt="" aria-hidden="true" />}
</article>

<style>
  .timeline-item {
    position: relative;
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    max-width: var(--content-max);
    margin: 0 auto;
    padding: clamp(3rem, 8vh, 6rem) clamp(1rem, 5vw, 4rem);
    align-items: center;
    overflow: hidden;
  }
  .timeline-item--left {
    grid-template-columns: auto 1fr;
    text-align: left;
  }
  .timeline-item--right {
    grid-template-columns: 1fr auto;
    text-align: right;
  }
  .timeline-item--right .timeline-item__meta {
    order: 2;
  }
  .timeline-item--right .timeline-item__content {
    order: 1;
  }

  /* Circles with bar between (the "double-circles" pattern from 2015) */
  .timeline-item__meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }
  .timeline-item__circle {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 1px solid var(--color-accent);
    display: grid;
    place-items: center;
    grid-template-rows: 1fr auto;
    padding: 0.5rem 0;
    background: var(--color-surface);
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 700ms var(--ease-smooth),
      transform 700ms var(--ease-smooth);
  }
  .timeline-item.is-visible .timeline-item__circle {
    opacity: 1;
    transform: scale(1);
  }
  .timeline-item.is-visible .timeline-item__circle:nth-of-type(2) {
    transition-delay: 200ms;
  }
  .timeline-item__month {
    font-family: var(--font-accent);
    font-style: italic;
    color: var(--color-accent-text);
    font-size: 14px;
    line-height: 1;
    padding-bottom: 4px;
  }
  .timeline-item__year {
    font-weight: 700;
    font-size: 22px;
    line-height: 1;
    color: var(--color-ink-soft);
  }
  .timeline-item__bar {
    width: 1px;
    height: 60px;
    background: var(--color-accent);
    transform-origin: top;
    transform: scaleY(0);
    transition: transform 600ms var(--ease-smooth) 100ms;
  }
  .timeline-item.is-visible .timeline-item__bar {
    transform: scaleY(1);
  }

  /* Content */
  .timeline-item__content {
    max-width: 65ch;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 700ms var(--ease-smooth) 200ms,
      transform 700ms var(--ease-smooth) 200ms;
  }
  .timeline-item.is-visible .timeline-item__content {
    opacity: 1;
    transform: translateY(0);
  }
  .timeline-item--right .timeline-item__content {
    margin-left: auto;
  }
  .timeline-item__content :global(h1) {
    font-size: var(--text-xl);
    text-transform: uppercase;
    letter-spacing: var(--tracking-upper);
    color: var(--color-ink-soft);
    margin-bottom: 0.25em;
    font-weight: 700;
  }
  .timeline-item__content :global(h2) {
    font-family: var(--font-accent);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--color-accent);
    margin-bottom: 1em;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
  }
  .timeline-item__content :global(h3) {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: var(--tracking-upper);
    color: var(--color-ink-softest);
    margin: 1.5em 0 0.5em;
    font-weight: 500;
  }
  .timeline-item__content :global(p) {
    color: var(--color-ink-soft);
    line-height: 1.65;
    margin-bottom: 0.75em;
  }
  .timeline-item__content :global(strong) {
    color: var(--color-ink);
    font-weight: 700;
  }

  .timeline-item__logo {
    position: absolute;
    width: 280px;
    height: auto;
    opacity: 0.08;
    pointer-events: none;
    z-index: -1;
    filter: grayscale(100%);
  }
  .timeline-item--left .timeline-item__logo {
    right: -4rem;
    bottom: -2rem;
  }
  .timeline-item--right .timeline-item__logo {
    left: -4rem;
    top: -2rem;
  }

  @media (max-width: 720px) {
    .timeline-item,
    .timeline-item--left,
    .timeline-item--right {
      grid-template-columns: 1fr;
      text-align: left;
    }
    .timeline-item--right .timeline-item__meta,
    .timeline-item--right .timeline-item__content {
      order: initial;
      margin-left: 0;
    }
    .timeline-item__meta {
      flex-direction: row;
      gap: 0;
    }
    .timeline-item__bar {
      width: 60px;
      height: 1px;
      transform: scaleX(0);
      transform-origin: left;
    }
    .timeline-item.is-visible .timeline-item__bar {
      transform: scaleX(1);
    }
    .timeline-item__circle { width: 80px; height: 80px; }
    .timeline-item__logo { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .timeline-item__circle,
    .timeline-item__bar,
    .timeline-item__content {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
