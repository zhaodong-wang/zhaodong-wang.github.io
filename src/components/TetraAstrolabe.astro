<div class="tetra-astrolabe" data-tetra-astrolabe aria-hidden="true">
  <canvas class="tetra-astrolabe__canvas" data-tetra-canvas></canvas>
  <div class="tetra-astrolabe__fallback">
    <img src="/img/myIcon.svg" alt="" width="220" height="220" loading="eager" />
  </div>
</div>

<style>
  .tetra-astrolabe {
    position: absolute;
    inset: 0;
    min-height: 420px;
    pointer-events: none;
    overflow: hidden;
  }

  .tetra-astrolabe__canvas,
  .tetra-astrolabe__fallback {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .tetra-astrolabe__canvas {
    display: block;
    opacity: 0;
    transition: opacity 900ms var(--ease-smooth);
  }

  .tetra-astrolabe[data-ready='true'] .tetra-astrolabe__canvas {
    opacity: 1;
  }

  .tetra-astrolabe__fallback {
    display: grid;
    place-items: center;
    opacity: 0.42;
    transition: opacity 700ms var(--ease-smooth);
  }

  .tetra-astrolabe__fallback img {
    width: min(34vw, 220px);
    height: auto;
    filter: invert(1) opacity(0.28);
  }

  .tetra-astrolabe[data-ready='true'] .tetra-astrolabe__fallback {
    opacity: 0;
  }

  @media (max-width: 760px) {
    .tetra-astrolabe {
      min-height: 360px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tetra-astrolabe__canvas {
      transition: none;
    }
  }
</style>

<script>
  import { setupTetraAstrolabe } from '../lib/tetra-astrolabe';

  setupTetraAstrolabe();
</script>
