---
interface Props {
  title: string;
  caption?: string;
  bgImage: string;
}

const { title, caption, bgImage } = Astro.props;
---

<section class="sub-hero">
  <div class="sub-hero__bg" style={`background-image: url('${bgImage}')`}></div>
  <div class="sub-hero__cover"></div>
  <div class="sub-hero__inner">
    <h1 class="sub-hero__title">{title}</h1>
    {caption && <p class="sub-hero__caption"><em>{caption}</em></p>}
  </div>
</section>

<style>
  .sub-hero {
    position: relative;
    min-height: 100vh;
    display: grid;
    place-items: center;
    overflow: hidden;
    isolation: isolate;
  }
  /* Background layer as a separate element so we can translateY it on
     scroll for the parallax effect the 2015 site had via
     #edu-home { background-position-y: -0.5 * scrollY }. Driven by a
     scroll listener (src/lib/parallax.ts) that writes --parallax-y
     on the hero section; the bg layer reads it via transform. */
  .sub-hero {
    --parallax-y: 0px;
  }
  .sub-hero__bg {
    position: absolute;
    inset: -10% 0;
    background-size: cover;
    background-position: center;
    z-index: -2;
    will-change: transform;
    transform: translateY(var(--parallax-y, 0));
  }
  @media (prefers-reduced-motion: reduce) {
    .sub-hero__bg { transform: none; }
  }
  .sub-hero__cover {
    position: absolute;
    inset: 0;
    background: rgba(17, 17, 17, 0.55);
    z-index: -1;
  }
  .sub-hero__inner {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 1.5rem;
  }
  .sub-hero__title {
    font-size: clamp(40px, 5.5vw, 78px);
    font-weight: 800;
    line-height: 1;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
  }
  @media (min-width: 601px) {
    .sub-hero__title { letter-spacing: var(--tracking-upper); }
  }
  .sub-hero__caption {
    font-family: var(--font-accent);
    font-style: italic;
    color: var(--color-accent);
    font-size: clamp(16px, 1.6vw, 22px);
    margin-top: 1.25em;
  }
</style>
