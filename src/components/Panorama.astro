---
interface Props {
  image: string;
  height?: string;
}
const { image, height = '60vh' } = Astro.props;
---

<section class="panorama" style={`--pano-h: ${height};`}>
  <div class="panorama__bg" style={`background-image: url('${image}')`}></div>
</section>

<style>
  /* Panorama divider between timeline items. legacy-motion.ts writes
     --parallax-y so the image drifts at the 2015 site's slower rate. */
  .panorama {
    position: relative;
    width: 100%;
    height: var(--pano-h);
    overflow: hidden;
    background: var(--color-surface-darker);
    --parallax-y: 0px;
  }
  .panorama__bg {
    position: absolute;
    inset: -15% 0;
    background-size: cover;
    background-position: center;
    will-change: transform;
    transform: translateY(var(--parallax-y, 0));
  }
  @media (prefers-reduced-motion: reduce) {
    .panorama__bg { transform: none; }
  }
</style>
