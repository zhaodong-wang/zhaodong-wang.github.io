---
interface Link {
  label: string;
  href: string;
}

const links: Link[] = [
  { label: 'Impact', href: '/#impact' },
  { label: 'Work', href: '/#work' },
  { label: 'Systems', href: '/#systems' },
  { label: 'Research', href: '/#research' },
  { label: 'Background', href: '/#background' },
  { label: 'Contact', href: '/#contact' },
];
---

<header class="site-header">
  <a href="/#home" class="site-header__logo" aria-label="Home">
    <span class="site-header__logo-mark is-active" data-logo-mark aria-hidden="true">
      <span class="site-header__logo-stick site-header__logo-stick--outer site-header__logo-stick--left"></span>
      <span class="site-header__logo-stick site-header__logo-stick--outer site-header__logo-stick--right"></span>
      <span class="site-header__logo-stick site-header__logo-stick--outer site-header__logo-stick--top"></span>
      <span class="site-header__logo-stick site-header__logo-stick--outer site-header__logo-stick--bottom"></span>
      <span class="site-header__logo-stick site-header__logo-stick--inner site-header__logo-stick--left"></span>
      <span class="site-header__logo-stick site-header__logo-stick--inner site-header__logo-stick--right"></span>
      <span class="site-header__logo-stick site-header__logo-stick--inner site-header__logo-stick--top"></span>
      <span class="site-header__logo-stick site-header__logo-stick--inner site-header__logo-stick--bottom"></span>
    </span>
  </a>
  <button
    class="site-header__menu"
    type="button"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="site-drawer"
    data-menu-toggle
  >
    <span></span>
    <span></span>
    <span></span>
  </button>
</header>

<nav
  id="site-drawer"
  class="site-drawer"
  aria-hidden="true"
  aria-label="Main navigation"
  data-drawer
>
  <div class="site-drawer__panels" aria-hidden="true">
    <div class="site-drawer__panel"><div class="site-drawer__panel-fill"></div></div>
    <div class="site-drawer__panel"><div class="site-drawer__panel-fill"></div></div>
    <div class="site-drawer__panel"><div class="site-drawer__panel-fill"></div></div>
    <div class="site-drawer__panel"><div class="site-drawer__panel-fill"></div></div>
  </div>
  <ul class="site-drawer__list">
    <li class="site-drawer__title"><em>Menu</em></li>
    {links.map((link) => (
      <li><a href={link.href}>{link.label}</a></li>
    ))}
  </ul>
</nav>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    height: var(--header-h);
    z-index: 100;
    pointer-events: none;
  }

  .site-header__logo {
    position: absolute;
    left: 0;
    top: 0;
    width: var(--header-h);
    height: var(--header-h);
    display: grid;
    place-items: center;
    background: var(--color-surface-dark);
    pointer-events: auto;
    will-change: transform;
  }
  .site-header__logo-mark {
    position: relative;
    display: block;
    width: 40px;
    height: 40px;
    overflow: visible;
    will-change: transform;
  }
  .site-header__logo-stick {
    position: absolute;
    left: 0;
    top: 0;
    width: 40px;
    height: 3px;
    background: var(--color-accent);
    transition: transform 0.6s var(--ease-smooth);
    will-change: transform;
  }
  .site-header__logo-stick--left {
    width: 37px;
    transform-origin: bottom left;
    transform: rotate(90deg);
  }
  .site-header__logo-stick--right {
    right: 0;
    left: auto;
    width: 37px;
    transform-origin: bottom right;
    transform: rotate(-90deg);
  }
  .site-header__logo-stick--top {
    transform-origin: bottom right;
  }
  .site-header__logo-stick--bottom {
    transform-origin: bottom left;
    transform: translateY(37px);
  }
  .site-header__logo-mark.is-active .site-header__logo-stick--left:not(.site-header__logo-stick--inner) {
    transform: rotate(90deg) scaleX(1.38) translateX(-12px);
  }
  .site-header__logo-mark.is-active .site-header__logo-stick--top:not(.site-header__logo-stick--inner) {
    transform: rotate(20.1deg) scaleX(1.3) translateX(7px);
  }
  .site-header__logo-mark.is-active .site-header__logo-stick--right:not(.site-header__logo-stick--inner) {
    transform: rotate(-70.1deg) scaleX(0.96) translate(3px, 12px);
  }
  .site-header__logo-mark.is-active .site-header__logo-stick--left.site-header__logo-stick--inner {
    transform: rotate(70deg) scaleX(1.1) translateX(-12px) translateY(-6px);
  }
  .site-header__logo-mark.is-active .site-header__logo-stick--right.site-header__logo-stick--inner {
    transform: rotate(30deg) scaleX(0.7) translate(23px, 33px);
  }
  .site-header__logo-mark.is-active .site-header__logo-stick--top.site-header__logo-stick--inner {
    transform: rotate(-30deg) scaleX(0.95) translate(7px, 9px);
  }
  .site-header__logo-mark.is-active .site-header__logo-stick--bottom.site-header__logo-stick--inner {
    transform: rotate(-42deg) scaleX(0.5) translate(-43px, 29px);
  }
  @media (prefers-reduced-motion: reduce) {
    .site-header__logo-stick {
      transition: none;
    }
  }

  .site-header__menu {
    position: absolute;
    right: clamp(1rem, 4vw, 3rem);
    top: 50%;
    translate: 0 -50%;
    width: 54px;
    height: 54px;
    padding: 0;
    border: 0;
    background: transparent;
    appearance: none;
    cursor: pointer;
    pointer-events: auto;
    display: block;
    overflow: hidden;
    transition: transform var(--dur-fast) var(--ease-smooth);
  }
  .site-header__menu span {
    position: absolute;
    left: 50%;
    top: 50%;
    display: block;
    width: 34px;
    height: 2px;
    margin: -1px 0 0 -17px;
    background: #7f7f7f;
    transform-origin: center center;
    will-change: transform, opacity, background-color;
  }
  .site-header__menu span:nth-child(1) { transform: translateY(-10px); }
  .site-header__menu span:nth-child(2) { transform: translateY(0); }
  .site-header__menu span:nth-child(3) { transform: translateY(10px); }
  .site-header__menu:hover,
  .site-header__menu:focus-visible {
    transform: translateY(-1px);
  }
  .site-header__menu:focus-visible {
    outline: 1px solid rgba(248, 246, 238, 0.58);
    outline-offset: 2px;
  }

  /* Drawer */
  .site-drawer {
    position: fixed;
    inset: 0;
    z-index: 90;
    pointer-events: none;
    visibility: hidden;
  }
  .site-drawer.is-open {
    pointer-events: auto;
    visibility: visible;
  }

  /* Four-panel curtain: each panel is a 25% column anchored to the right
     edge, width 0 → 100%, staggered by 80ms so the panels sweep in like
     a curtain. Matches the 2015 .nav-column .fill behaviour. */
  .site-drawer__panels {
    position: absolute;
    inset: 0;
    display: flex;
  }
  .site-drawer__panel {
    flex: 1 1 25%;
    position: relative;
    border-right: 1px solid #1d1d1d;
    overflow: hidden;
  }
  .site-drawer__panel-fill {
    position: absolute;
    inset: 0 -2px;
    background: #111;
    transform: scaleX(0);
    transform-origin: right center;
    will-change: transform;
  }

  .site-drawer__list {
    position: absolute;
    top: clamp(112px, 17vh, 180px);
    right: clamp(24px, 8vw, 112px);
    width: min(72vw, 560px);
    margin: 0;
    padding: 0;
    list-style: none;
    text-align: right;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25em;
  }
  /* Menu items slide in from the right — base state (closed) is translateX 80%
     opacity 0, matching the 2015 .move-right class. On open they settle to 0/1
     with a first-to-last stagger; on close they retreat with a last-to-first
     reverse stagger so the last-in is the first-out (matches the 2015 toggleMenu
     JS behaviour). Typography stays in a light grotesk voice. */
  .site-drawer__list li {
    opacity: 0;
    will-change: transform, opacity;
  }

  .site-drawer__title {
    font-family: var(--font-accent);
    font-style: italic;
    color: var(--color-accent);
    font-size: var(--text-lg);
    margin-bottom: 0.5em;
    font-weight: 400;
  }
  .site-drawer__list a {
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: var(--tracking-nav);
    font-weight: 300;
    font-size: clamp(28px, 3.2vw, 42px);
    line-height: 1.08;
    color: #fff;
    text-shadow: 0 0 10px rgba(0, 0, 0, 0.55);
    transition: color var(--dur-fast) var(--ease-smooth);
  }
  .site-drawer__list a:hover {
    color: var(--color-accent);
  }
  .site-drawer__list a:focus-visible {
    color: #fff;
    outline: 1px solid var(--color-accent);
    outline-offset: 5px;
  }

  :global(body.drawer-open) {
    overflow: hidden;
  }

  @media (max-width: 720px) {
    .site-header__menu {
      right: 22px;
      width: 50px;
      height: 50px;
    }
    .site-header__menu span {
      width: 32px;
      margin-left: -16px;
    }
    .site-drawer__panel {
      border-right-color: #1d1d1d;
    }
    .site-drawer__list {
      top: clamp(150px, 30vh, 220px);
      right: 30px;
      width: min(68vw, 300px);
      gap: 0.42em;
    }
    .site-drawer__list a {
      font-size: clamp(27px, 7vw, 34px);
      line-height: 1.02;
      letter-spacing: 0.035em;
    }
  }

  @media (max-width: 420px) {
    .site-drawer__list {
      right: 24px;
      width: calc(100vw - 96px);
    }
    .site-drawer__list a {
      font-size: clamp(24px, 7.2vw, 30px);
    }
  }
</style>

<script>
  import { setupLegacyDrawer } from '../lib/legacy-motion';
  setupLegacyDrawer();
</script>
