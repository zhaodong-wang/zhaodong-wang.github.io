---
interface Link {
  label: string;
  href: string;
}

const links: Link[] = [
  { label: 'Home', href: '/#home' },
  { label: 'About', href: '/#about' },
  { label: 'Education', href: '/education/' },
  { label: 'Projects', href: '/projects/' },
  { label: 'Publications', href: '/publications/' },
  { label: 'Skills', href: '/skills/' },
  { label: 'Contact', href: '/#contact' },
];
---

<header class="site-header">
  <a href="/#home" class="site-header__logo" aria-label="Home">
    <img src="/img/myIcon.svg" alt="" width="60" height="60" />
  </a>
  <button
    class="site-header__menu"
    type="button"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="site-drawer"
    data-menu-toggle
  >
    <span></span>
    <span></span>
    <span></span>
  </button>
</header>

<nav
  id="site-drawer"
  class="site-drawer"
  aria-hidden="true"
  aria-label="Main navigation"
  data-drawer
>
  <div class="site-drawer__panels" aria-hidden="true">
    <div class="site-drawer__panel"></div>
    <div class="site-drawer__panel"></div>
    <div class="site-drawer__panel"></div>
    <div class="site-drawer__panel"></div>
  </div>
  <ul class="site-drawer__list">
    <li class="site-drawer__title"><em>Menu</em></li>
    {links.map((link) => (
      <li><a href={link.href}>{link.label}</a></li>
    ))}
  </ul>
</nav>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    height: var(--header-h);
    z-index: 100;
    pointer-events: none;
  }

  .site-header__logo {
    position: absolute;
    left: 0;
    top: 0;
    width: var(--header-h);
    height: var(--header-h);
    display: grid;
    place-items: center;
    background: var(--color-surface-dark);
    pointer-events: auto;
    transition: transform 600ms cubic-bezier(0.835, 0, 0.19, 1);
  }
  /* Hide the logo when the drawer is open — matches 2015 .nav-link-home.hide */
  :global(body.drawer-open) .site-header__logo {
    transform: translateY(-100%);
  }
  .site-header__logo img {
    width: 60%;
    height: 60%;
    object-fit: contain;
  }
  @media (max-width: 600px) {
    .site-header__logo img { width: 65%; height: 65%; }
  }

  .site-header__menu {
    position: absolute;
    right: clamp(1rem, 4vw, 3rem);
    top: 50%;
    translate: 0 -50%;
    width: 44px;
    height: 30px;
    pointer-events: auto;
    display: grid;
    align-content: space-between;
  }
  .site-header__menu span {
    display: block;
    height: 2px;
    background: #7f7f7f;
    transition: transform 600ms cubic-bezier(0.6, 0, 0.4, 1),
      opacity var(--dur-fast) var(--ease-smooth),
      background-color 800ms cubic-bezier(0.075, 0.82, 0.165, 1);
    transform-origin: right center;
  }
  /* When the drawer is open: bars shift to light gray and collapse into an X.
     Color shift matches 2015 #7f7f7f -> #ccc transition from main.js. */
  .site-header__menu[aria-expanded='true'] span {
    background: #ccc;
  }
  .site-header__menu[aria-expanded='true'] span:nth-child(1) {
    transform: translateX(-3px) rotate(-45deg);
  }
  .site-header__menu[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .site-header__menu[aria-expanded='true'] span:nth-child(3) {
    transform: translateX(-3px) rotate(45deg);
  }

  /* Drawer */
  .site-drawer {
    position: fixed;
    inset: 0;
    z-index: 90;
    pointer-events: none;
    visibility: hidden;
  }
  .site-drawer.is-open {
    pointer-events: auto;
    visibility: visible;
  }

  /* Four-panel curtain: each panel is a 25% column anchored to the right
     edge, width 0 → 100%, staggered by 80ms so the panels sweep in like
     a curtain. Matches the 2015 .nav-column .fill behaviour. */
  .site-drawer__panels {
    position: absolute;
    inset: 0;
    display: flex;
  }
  .site-drawer__panel {
    flex: 1 1 25%;
    position: relative;
    border-right: 1px solid rgba(170, 170, 170, 0.15);
  }
  .site-drawer__panel::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    height: 100%;
    width: 0;
    background: rgba(0, 0, 0, 0.92);
    transition: width 500ms cubic-bezier(1, 0, 0, 1);
  }
  .site-drawer.is-open .site-drawer__panel::before {
    width: 100%;
  }
  .site-drawer__panel:nth-child(1)::before { transition-delay: 0ms; }
  .site-drawer__panel:nth-child(2)::before { transition-delay: 80ms; }
  .site-drawer__panel:nth-child(3)::before { transition-delay: 160ms; }
  .site-drawer__panel:nth-child(4)::before { transition-delay: 240ms; }
  /* On close, panels retreat in reverse order so the last-in is first-out */
  .site-drawer:not(.is-open) .site-drawer__panel:nth-child(1)::before { transition-delay: 240ms; }
  .site-drawer:not(.is-open) .site-drawer__panel:nth-child(2)::before { transition-delay: 160ms; }
  .site-drawer:not(.is-open) .site-drawer__panel:nth-child(3)::before { transition-delay: 80ms; }
  .site-drawer:not(.is-open) .site-drawer__panel:nth-child(4)::before { transition-delay: 0ms; }

  .site-drawer__list {
    position: absolute;
    top: 14%;
    right: 8%;
    margin: 0;
    padding: 0;
    list-style: none;
    text-align: right;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25em;
  }
  /* Menu items slide in from the right — base state (closed) is translateX 80%
     opacity 0, matching the 2015 .move-right class. On open they settle to 0/1
     with a first-to-last stagger; on close they retreat with a last-to-first
     REVERSE stagger so the last-in is the first-out (matches the 2015 toggleMenu
     JS behaviour). Typography: 150% of 20px (30px) Brandon, weight 400. */
  .site-drawer__list li {
    opacity: 0;
    transform: translateX(80%);
    transition:
      opacity 500ms cubic-bezier(0.19, 1, 0.22, 1),
      transform 500ms cubic-bezier(0.19, 1, 0.22, 1);
  }
  .site-drawer.is-open .site-drawer__list li {
    opacity: 1;
    transform: translateX(0);
  }
  /* Open stagger: first→last, starts after the curtain begins to fill */
  .site-drawer.is-open .site-drawer__list li:nth-child(1) { transition-delay: 420ms; }
  .site-drawer.is-open .site-drawer__list li:nth-child(2) { transition-delay: 490ms; }
  .site-drawer.is-open .site-drawer__list li:nth-child(3) { transition-delay: 560ms; }
  .site-drawer.is-open .site-drawer__list li:nth-child(4) { transition-delay: 630ms; }
  .site-drawer.is-open .site-drawer__list li:nth-child(5) { transition-delay: 700ms; }
  .site-drawer.is-open .site-drawer__list li:nth-child(6) { transition-delay: 770ms; }
  .site-drawer.is-open .site-drawer__list li:nth-child(7) { transition-delay: 840ms; }
  .site-drawer.is-open .site-drawer__list li:nth-child(8) { transition-delay: 910ms; }
  /* Close stagger: last→first — the 8th child leaves first with 0ms delay */
  .site-drawer:not(.is-open) .site-drawer__list li:nth-child(1) { transition-delay: 490ms; }
  .site-drawer:not(.is-open) .site-drawer__list li:nth-child(2) { transition-delay: 420ms; }
  .site-drawer:not(.is-open) .site-drawer__list li:nth-child(3) { transition-delay: 350ms; }
  .site-drawer:not(.is-open) .site-drawer__list li:nth-child(4) { transition-delay: 280ms; }
  .site-drawer:not(.is-open) .site-drawer__list li:nth-child(5) { transition-delay: 210ms; }
  .site-drawer:not(.is-open) .site-drawer__list li:nth-child(6) { transition-delay: 140ms; }
  .site-drawer:not(.is-open) .site-drawer__list li:nth-child(7) { transition-delay: 70ms; }
  .site-drawer:not(.is-open) .site-drawer__list li:nth-child(8) { transition-delay: 0ms; }

  .site-drawer__title {
    font-family: var(--font-accent);
    font-style: italic;
    color: var(--color-accent);
    font-size: var(--text-lg);
    margin-bottom: 0.5em;
    font-weight: 400;
  }
  .site-drawer__list a {
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 300;
    font-size: var(--text-lg);
    color: #fff;
    transition: color var(--dur-fast) var(--ease-smooth);
  }
  .site-drawer__list a:hover,
  .site-drawer__list a:focus-visible {
    color: var(--color-accent);
  }

  :global(body.drawer-open) {
    overflow: hidden;
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const drawer = document.querySelector<HTMLElement>('[data-drawer]');

  if (toggle && drawer) {
    const focusables = () =>
      Array.from(
        drawer.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
        ),
      );

    const open = () => {
      drawer.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.classList.add('drawer-open');
      // Focus the first link after the curtain animation settles
      requestAnimationFrame(() => {
        focusables()[0]?.focus();
      });
    };

    const close = () => {
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('drawer-open');
      toggle.focus();
    };

    toggle.addEventListener('click', () => {
      drawer.classList.contains('is-open') ? close() : open();
    });

    // Focus trap: when the drawer is open, cycle Tab between its focusables.
    // Escape always closes. Tab on the last wraps to the first; Shift+Tab on
    // the first wraps to the last.
    document.addEventListener('keydown', (e) => {
      if (!drawer.classList.contains('is-open')) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        close();
        return;
      }
      if (e.key !== 'Tab') return;
      const list = focusables();
      if (!list.length) return;
      const first = list[0];
      const last = list[list.length - 1];
      const active = document.activeElement;
      if (e.shiftKey && active === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && active === last) {
        e.preventDefault();
        first.focus();
      }
    });

    drawer.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', close);
    });
  }
</script>
