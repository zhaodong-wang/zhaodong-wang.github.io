---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not Found — Zhaodong Wang" description="The page you are looking for does not exist.">
  <section class="notfound">
    <div class="notfound__inner">
      <p class="notfound__code"><em>404</em></p>
      <h1 class="notfound__title">Lost in the network</h1>
      <p class="notfound__body">
        That page is not routable. Try heading back to the
        <a href="/">home page</a>, or jump to the
        <a href="/#research">research signal</a>.
      </p>
    </div>
  </section>
</Layout>

<style>
  .notfound {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: var(--section-pad) 1.5rem;
    background: rgba(214, 214, 214, 0.35);
  }
  .notfound__inner {
    text-align: center;
    max-width: 50ch;
  }
  .notfound__code {
    font-family: var(--font-accent);
    font-style: italic;
    color: var(--color-accent);
    font-size: clamp(80px, 16vw, 180px);
    line-height: 1;
    margin: 0 0 0.25em;
  }
  .notfound__title {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-display);
    text-transform: uppercase;
    letter-spacing: var(--tracking-heading);
    color: var(--color-ink-soft);
    margin-bottom: 1em;
  }
  .notfound__body {
    color: var(--color-ink-softer);
    line-height: 1.6;
  }
  .notfound__body a {
    color: var(--color-accent-deep);
    border-bottom: 1px solid currentColor;
  }
  .notfound__body a:hover {
    color: var(--color-accent);
  }
</style>
