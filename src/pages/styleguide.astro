---
import Layout from '../layouts/Layout.astro';

const colors = [
  { name: '--color-accent', value: '#bc8420' },
  { name: '--color-accent-deep', value: '#714f13' },
  { name: '--color-ink', value: '#000' },
  { name: '--color-ink-soft', value: '#333' },
  { name: '--color-ink-softer', value: '#555' },
  { name: '--color-ink-softest', value: '#666' },
  { name: '--color-rule', value: '#aaa' },
  { name: '--color-rule-soft', value: '#ccc' },
  { name: '--color-rule-softer', value: '#ddd' },
  { name: '--color-rule-softest', value: '#eee' },
  { name: '--color-surface', value: '#fff' },
  { name: '--color-surface-dark', value: '#222' },
  { name: '--color-surface-darker', value: '#111' },
];

const weights = [100, 300, 400, 500, 700, 900];
---

<Layout title="Styleguide — Zhaodong Wang">
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>

  <main class="sg">
    <header class="sg__hero">
      <h1>Design tokens</h1>
      <p class="sg__lede">
        Internal reference. Ported from the original <em>css/main.css</em> so
        the rebuilt site stays visually consistent with the 2015 version.
      </p>
    </header>

    <section class="sg__section">
      <h2>Color</h2>
      <div class="sg__swatches">
        {colors.map((c) => (
          <figure class="sg__swatch">
            <div class="sg__chip" style={`background:${c.value}`}></div>
            <figcaption>
              <code>{c.name}</code>
              <span>{c.value}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section class="sg__section">
      <h2>Typography — Brandon Grotesque</h2>
      <div class="sg__type">
        <div class="sg__row">
          <span class="sg__label"><code>h1</code> · 96px / 900</span>
          <h1 class="sg__sample">Zhaodong</h1>
        </div>
        <div class="sg__row">
          <span class="sg__label"><code>h2</code> · 64px / 700</span>
          <h2 class="sg__sample">Meta Superintelligence Lab</h2>
        </div>
        <div class="sg__row">
          <span class="sg__label"><code>h3</code> · 28px / 700 / accent</span>
          <h3 class="sg__sample">Senior Staff Research Scientist</h3>
        </div>
        <div class="sg__row">
          <span class="sg__label"><code>body</code> · 20px / 400</span>
          <p class="sg__sample">
            The quick brown fox jumps over the lazy dog — 0123456789
          </p>
        </div>
      </div>
      <div class="sg__weights">
        {weights.map((w) => (
          <div class="sg__weight">
            <span class="sg__label">{w}</span>
            <span class="sg__sample" style={`font-weight:${w}`}>
              Brandon {w}
            </span>
            <span class="sg__sample sg__sample--italic" style={`font-weight:${w}`}>
              Brandon {w} italic
            </span>
          </div>
        ))}
      </div>
    </section>

    <section class="sg__section">
      <h2>Typography — Adobe Caslon Pro</h2>
      <p class="sg__row">
        <span class="sg__label">accent · italic</span>
        <em class="sg__sample">Used sparingly for emphasis and pull quotes.</em>
      </p>
    </section>

    <section class="sg__section">
      <h2>Motion</h2>
      <p class="sg__lede">
        Hover the bars to replay. These are the two signature easing curves
        from the old site — porting them verbatim keeps the feel identical.
      </p>
      <div class="sg__motion">
        <div class="sg__motion-row">
          <span class="sg__label"><code>--ease-smooth</code><br />cubic-bezier(0.6, 0, 0.4, 1)</span>
          <div class="sg__track"><div class="sg__ball sg__ball--smooth"></div></div>
        </div>
        <div class="sg__motion-row">
          <span class="sg__label"><code>--ease-snap</code><br />cubic-bezier(0.835, 0, 0.19, 1)</span>
          <div class="sg__track"><div class="sg__ball sg__ball--snap"></div></div>
        </div>
      </div>
    </section>

    <section class="sg__section">
      <h2>Layout tokens</h2>
      <ul class="sg__list">
        <li><code>--header-h</code> — 90px (60px mobile)</li>
        <li><code>--section-pad</code> — 60px (40px mobile)</li>
        <li><code>--content-max</code> — 1200px</li>
        <li><code>--tracking-upper</code> — 0.125em (applied to all uppercase headings)</li>
      </ul>
    </section>
  </main>
</Layout>

<style>
  .sg {
    max-width: 1100px;
    margin-inline: auto;
    padding: calc(var(--header-h) + var(--section-pad)) 1.5rem
      var(--section-pad);
  }

  .sg__hero {
    border-bottom: 1px solid var(--color-rule-soft);
    padding-bottom: var(--section-pad);
    margin-bottom: var(--section-pad);
  }
  .sg__lede {
    color: var(--color-ink-soft);
    max-width: 60ch;
    margin-top: 1rem;
  }

  .sg__section {
    padding: var(--section-pad) 0;
    border-bottom: 1px solid var(--color-rule-softer);
  }
  .sg__section > h2 {
    margin-bottom: 1.5rem;
  }

  /* Color swatches */
  .sg__swatches {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
  }
  .sg__swatch {
    margin: 0;
    border: 1px solid var(--color-rule-soft);
    border-radius: 4px;
    overflow: hidden;
  }
  .sg__chip {
    aspect-ratio: 16 / 9;
  }
  .sg__swatch figcaption {
    padding: 0.75rem;
    font-size: 14px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .sg__swatch code {
    color: var(--color-ink);
    font-family: ui-monospace, monospace;
    font-size: 12px;
  }
  .sg__swatch span {
    color: var(--color-ink-softest);
    font-family: ui-monospace, monospace;
    font-size: 12px;
  }

  /* Type scale */
  .sg__type,
  .sg__weights,
  .sg__motion {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .sg__row,
  .sg__weight,
  .sg__motion-row {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 1.5rem;
    align-items: baseline;
  }
  .sg__label {
    font-size: 12px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-ink-softest);
    font-family: ui-monospace, monospace;
  }
  .sg__sample {
    font-family: var(--font-body);
    margin: 0;
  }
  .sg__sample--italic {
    font-style: italic;
  }
  .sg__weight {
    padding: 0.5rem 0;
    border-bottom: 1px dashed var(--color-rule-softer);
  }
  .sg__weight .sg__sample {
    font-size: 22px;
  }

  /* Motion demos */
  .sg__motion-row {
    align-items: center;
  }
  .sg__track {
    position: relative;
    height: 40px;
    background: var(--color-rule-softest);
    border-radius: 999px;
    overflow: hidden;
  }
  .sg__ball {
    position: absolute;
    top: 4px;
    left: 4px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-accent);
    transform: translateX(0);
  }
  .sg__ball--smooth {
    animation: roll 2s var(--ease-smooth) infinite alternate;
  }
  .sg__ball--snap {
    animation: roll 2s var(--ease-snap) infinite alternate;
  }
  @keyframes roll {
    from { transform: translateX(0); }
    to   { transform: translateX(calc(100% + 8px - 32px)); }
  }

  /* Layout list */
  .sg__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--color-ink-soft);
  }
  .sg__list code {
    color: var(--color-accent-deep);
    font-family: ui-monospace, monospace;
  }

  @media (max-width: 600px) {
    .sg__row,
    .sg__weight,
    .sg__motion-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
