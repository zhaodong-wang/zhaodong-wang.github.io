---
import Layout from '../layouts/Layout.astro';
import LogoMark from '../components/LogoMark.astro';
import NextArrow from '../components/NextArrow.astro';
import TetraAstrolabe from '../components/TetraAstrolabe.astro';

const impactStats = [
  {
    value: 'Ship',
    label: 'Production agent systems',
    detail:
      'Build AI agents for real work surfaces, where reliability, tool use, and trust matter more than demos.',
  },
  {
    value: 'Build',
    label: 'Product + infrastructure',
    detail:
      'Own the connective tissue across product UX, orchestration, memory, tools, evaluation, and debugging.',
  },
  {
    value: 'Loop',
    label: 'Research to product',
    detail:
      'Turn frontier model behavior into measured software systems through shipping, observation, and iteration.',
  },
];

const workRows = [
  {
    eyebrow: 'Agent platforms',
    title: 'I build the product surface and the system underneath it.',
    body:
      'Harnesses, orchestration, tools, memory, evaluation loops, debugging surfaces, and the product patterns that make agents usable by real people.',
  },
  {
    eyebrow: 'Model-product loops',
    title: 'I turn frontier behavior into reliable software.',
    body:
      'The work is a tight loop between modeling, product, infrastructure, and user friction: ship, observe, evaluate, and feed the hard cases back into the system.',
  },
  {
    eyebrow: 'Systems taste',
    title: 'I care about reliability, legibility, and the last mile.',
    body:
      'My background spans ML systems, distributed infrastructure, traffic engineering, research prototypes, and production product engineering.',
  },
];

const systemRows = [
  {
    title: 'Production agent platforms',
    meta: 'Meta TBD Lab / Agentic AI',
    body:
      'Led product and systems work on production AI agents, spanning user surfaces, harnesses, tools, and evaluation loops.',
  },
  {
    title: 'Agent harnesses and eval loops',
    meta: 'Product + Modeling',
    body:
      'Co-designing the scaffolding that lets agents use tools, remember context, recover from mistakes, and improve through measured feedback.',
  },
  {
    title: 'ML systems and network intelligence',
    meta: 'Meta / Netflix / Research',
    body:
      'Built prediction, optimization, automation, and applied ML systems for infrastructure at production scale.',
  },
];

const researchHighlights = [
  {
    label: 'Confucius Code Agent, 2026',
    href: 'https://arxiv.org/abs/2512.10398',
  },
  {
    label: 'REA, Meta Engineering, 2026',
    href:
      'https://engineering.fb.com/2026/03/17/developer-tools/ranking-engineer-agent-rea-autonomous-ai-system-accelerating-meta-ads-ranking-innovation/',
  },
  {
    label: 'Confucius Framework, SIGCOMM 2025',
    href: 'https://dl.acm.org/doi/10.1145/3718958.3750537',
  },
  {
    label: 'LayerDAG, ICLR Spotlight 2025',
    href: 'https://openreview.net/forum?id=kam84eEmub',
  },
  {
    label: 'MCCS, SIGCOMM 2024',
    href: 'https://dl.acm.org/doi/10.1145/3651890.3672252',
  },
  {
    label: 'Neural WAN TE, SIGCOMM 2024',
    href: 'https://dl.acm.org/doi/10.1145/3651890.3672237',
  },
];

const backgroundRows = [
  {
    period: '2022 - Present',
    title: 'Meta TBD Lab',
    body: 'AI Research Scientist leading agentic AI products and systems.',
  },
  {
    period: '2021 - 2022',
    title: 'Netflix',
    body: 'Senior Research Engineer on ML systems and production infrastructure.',
  },
  {
    period: 'Education',
    title: 'UIUC + Tsinghua',
    body:
      'Ph.D. Transportation, M.S. Applied Mathematics, and B.E. Civil Engineering and Economics.',
  },
];
---

<Layout
  title="Zhaodong Wang"
  description="Zhaodong Wang is an AI Research Scientist at Meta TBD Lab building production AI agents, ML systems, and product infrastructure."
>
  <div class="site-particle-field" aria-hidden="true">
    <TetraAstrolabe />
  </div>

  <div class="opening-loader" data-opening-loader aria-hidden="true">
    <div class="opening-loader__mark" data-opening-mark>
      <LogoMark />
    </div>
  </div>

  <section id="home" class="home">
    <div class="home__cover" aria-hidden="true"></div>

    <div class="home__inner">
      <div class="home__line" style="--delay: 0ms">
        <p class="home__kicker" data-scramble-text>AI Research Scientist / Meta TBD Lab</p>
      </div>
      <div class="home__line home__line--title" style="--delay: 120ms">
        <h1 class="home__title" data-home-title>Zhaodong Wang</h1>
      </div>
      <div class="home__line" style="--delay: 260ms">
        <p class="home__deck" data-home-deck>
          I build production AI agents, ML systems, and research-to-product loops for
          software that has to work every day.
        </p>
      </div>
      <div class="home__line" style="--delay: 420ms">
        <p
          class="home__scope"
          aria-label="AI agents / ML systems / product engineering / applied research"
          data-home-scope
        >
          <span data-scope-phrase>AI agents</span>
          <span class="home__scope-separator" aria-hidden="true">/</span>
          <span data-scope-phrase>ML systems</span>
          <span class="home__scope-separator" aria-hidden="true">/</span>
          <span data-scope-phrase>product engineering</span>
          <span class="home__scope-separator" aria-hidden="true">/</span>
          <span data-scope-phrase>applied research</span>
        </p>
      </div>
    </div>

    <aside class="home__side-label" aria-label="Current location and date">
      <span>2026</span>
      <span>Menlo Park</span>
    </aside>

    <NextArrow href="#impact" label="Scroll to impact" />
  </section>

  <article class="paper" aria-label="Selected portfolio">
    <section id="impact" class="impact" aria-labelledby="impact-heading">
      <div class="section-intro" data-reveal>
        <p class="paper-label">One paper / recent focus</p>
        <h2 id="impact-heading">Agent infrastructure, compressed.</h2>
      </div>

      <div class="impact__body" data-reveal>
        <p>
          The old site was a research archive. This version is intentionally narrower:
          recent agent systems first, research as proof, education as context.
        </p>
      </div>

      <dl class="stat-ledger">
        {impactStats.map((stat, index) => (
          <div data-reveal style={`--delay: ${index * 90}ms`}>
            <dt>{stat.value}</dt>
            <dd>
              <span>{stat.label}</span>
              <p>{stat.detail}</p>
            </dd>
          </div>
        ))}
      </dl>
    </section>

    <section id="work" class="paper-section" aria-labelledby="work-heading">
      <div class="section-intro" data-reveal>
        <p class="paper-label">What I do now</p>
        <h2 id="work-heading">I make agents operational.</h2>
      </div>

      <div class="ledger">
        {workRows.map((item, index) => (
          <article class="ledger__row" data-reveal style={`--delay: ${index * 90}ms`}>
            <span>{item.eyebrow}</span>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="systems" class="paper-section paper-section--systems" aria-labelledby="systems-heading">
      <div class="section-intro" data-reveal>
        <p class="paper-label">Selected systems</p>
        <h2 id="systems-heading">Recent work that defines the profile.</h2>
      </div>

      <div class="system-ledger">
        {systemRows.map((item, index) => (
          <article class="system-ledger__row" data-reveal style={`--delay: ${index * 90}ms`}>
            <span>{item.meta}</span>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="research" class="research" aria-labelledby="research-heading">
      <div class="section-intro" data-reveal>
        <p class="paper-label">Research signal</p>
        <h2 id="research-heading">Research is present, not the whole story.</h2>
      </div>

      <ul class="research__list">
        {researchHighlights.map((item, index) => (
          <li data-reveal style={`--delay: ${index * 55}ms`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <strong>
              <a href={item.href} target="_blank" rel="noopener noreferrer">
                {item.label}
              </a>
            </strong>
          </li>
        ))}
      </ul>
    </section>

    <section id="background" class="background" aria-labelledby="background-heading">
      <div class="section-intro" data-reveal>
        <p class="paper-label">Background</p>
        <h2 id="background-heading">A compact arc.</h2>
      </div>

      <div class="background__rows">
        {backgroundRows.map((item, index) => (
          <article class="background__row" data-reveal style={`--delay: ${index * 90}ms`}>
            <span>{item.period}</span>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="contact" class="contact" aria-labelledby="contact-heading">
      <div class="contact__copy" data-reveal>
        <p class="paper-label">Contact</p>
        <h2 id="contact-heading">Building agent systems and AI products.</h2>
        <button class="contact__email" type="button" data-contact-email>
          Email me
        </button>
      </div>
    </section>
  </article>
</Layout>

<style>
  :global(html) {
    scroll-behavior: smooth;
    background: #f2f2ef;
  }

  :global(main) {
    display: block;
    background: #f2f2ef;
  }

  .site-particle-field {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: #101010;
  }

  .opening-loader {
    position: fixed;
    inset: 0;
    z-index: 120;
    display: grid;
    place-items: center;
    background: #222;
    pointer-events: none;
  }

  .opening-loader__mark {
    position: relative;
    width: 40px;
    height: 40px;
    opacity: 0;
    overflow: visible;
    will-change: transform, opacity;
  }

  .home {
    position: relative;
    z-index: 1;
    min-height: 100svh;
    display: grid;
    align-items: end;
    padding: calc(var(--header-h) + clamp(42px, 7vw, 96px)) clamp(24px, 7vw, 96px)
      clamp(76px, 10vw, 132px);
    color: #f8f6ee;
    background: transparent;
    overflow: hidden;
    isolation: isolate;
  }

  .home::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.032) 1px, transparent 1px);
    background-size: 25vw 100%, 100% 25vh;
    opacity: 0.18;
    pointer-events: none;
    z-index: 0;
  }

  .home::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      #101010 0%,
      rgba(16, 16, 16, 0.96) 34%,
      rgba(16, 16, 16, 0.38) 58%,
      transparent 76%
    );
  }

  .home__cover {
    position: absolute;
    inset: 0;
    background: #101010;
    opacity: 0;
    z-index: 4;
    pointer-events: none;
  }

  .home__inner {
    position: relative;
    z-index: 3;
    width: min(820px, 86vw);
    padding-left: clamp(0px, 4vw, 58px);
  }

  .home__line {
    display: block;
    overflow: hidden;
    padding: 0.03em 0;
  }

  .home__line--title {
    padding: 0.03em 0 clamp(14px, 1.2vw, 18px);
  }

  .home__line > * {
    opacity: 0;
    will-change: transform, opacity;
  }

  .home__kicker,
  .paper-label,
  .ledger__row span,
  .system-ledger__row span,
  .research__list span,
  .background__row span {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: 0.045em;
    text-transform: uppercase;
  }

  .home__kicker {
    color: var(--color-accent);
  }

  .home__title {
    max-width: 8.8ch;
    margin: 0.15em 0 0;
    color: #faf8f0;
    font-size: 6rem;
    font-weight: 600;
    line-height: 0.94;
    letter-spacing: -0.035em;
    text-transform: none;
    text-wrap: balance;
  }

  .home__title :global(.home__title-word) {
    display: inline-block;
    will-change: transform, opacity;
    transform-origin: 50% 85%;
  }

  .home__deck {
    max-width: 36rem;
    margin: 1.35rem 0 0;
    color: rgba(248, 246, 238, 0.8);
    font-size: 1.28rem;
    font-weight: 400;
    line-height: 1.48;
    letter-spacing: 0;
  }

  .home__deck :global(.home__deck-line),
  .home__deck :global(.home__deck-line-mask) {
    display: block;
  }

  .home__deck :global(.home__deck-line) {
    will-change: transform, opacity;
  }

  .home__scope {
    display: flex;
    flex-wrap: wrap;
    gap: 0.12em 0.42em;
    max-width: 34rem;
    margin: 1.7rem 0 0;
    color: rgba(248, 246, 238, 0.58);
    font-size: 0.92rem;
    font-weight: 650;
    line-height: 1.5;
    letter-spacing: 0.035em;
    text-transform: uppercase;
  }

  .home__scope :global([data-scope-phrase]) {
    display: inline-block;
    color: rgba(248, 246, 238, 0.58);
    transition: color 420ms var(--ease-smooth);
    will-change: color;
  }

  .home__scope :global([data-scope-phrase]:hover) {
    color: rgba(248, 246, 238, 0.92);
  }

  .home__scope-separator {
    color: rgba(188, 132, 32, 0.54);
  }

  .home__side-label {
    position: absolute;
    left: clamp(18px, 2.8vw, 42px);
    top: 50%;
    z-index: 3;
    transform: translateY(-50%);
    display: grid;
    gap: 1.1rem;
    color: rgba(248, 246, 238, 0.56);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    line-height: 1;
    text-transform: uppercase;
    writing-mode: vertical-rl;
  }

  .home__side-label::before {
    content: '';
    width: 1px;
    height: 96px;
    margin: 0.2rem auto;
    background: rgba(248, 246, 238, 0.3);
  }

  .home :global(.next-arrow) {
    z-index: 5;
    opacity: 0;
    border-color: rgba(248, 246, 238, 0.3);
  }

  .home :global(.next-arrow__bar) {
    background: rgba(248, 246, 238, 0.7);
  }

  .home :global(.next-arrow:hover),
  .home :global(.next-arrow:focus-visible) {
    border-color: var(--color-accent);
  }

  .home :global(.next-arrow:hover .next-arrow__bar),
  .home :global(.next-arrow:focus-visible .next-arrow__bar) {
    background: var(--color-accent);
  }

  .paper {
    position: relative;
    z-index: 1;
    background: rgba(242, 242, 239, 0.82);
    backdrop-filter: blur(0.25px);
    color: #141414;
  }

  .impact,
  .paper-section,
  .research,
  .background,
  .contact {
    width: min(100% - 48px, 1240px);
    margin-inline: auto;
    border-top: 1px solid rgba(20, 20, 20, 0.18);
    scroll-margin-top: calc(var(--header-h) + 24px);
  }

  .impact {
    display: grid;
    grid-template-columns: minmax(360px, 0.72fr) minmax(480px, 1fr);
    gap: clamp(28px, 5vw, 76px);
    padding: clamp(72px, 9vw, 126px) 0 clamp(76px, 10vw, 140px);
  }

  .paper-section,
  .research,
  .background {
    display: grid;
    grid-template-columns: minmax(280px, 0.68fr) minmax(420px, 1fr);
    gap: clamp(32px, 6vw, 96px);
    padding: clamp(78px, 11vw, 150px) 0;
  }

  .contact {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(28px, 5vw, 72px);
    align-items: end;
    padding: clamp(82px, 12vw, 156px) 0 clamp(96px, 13vw, 176px);
  }

  .paper-label {
    color: var(--color-accent-text);
  }

  .section-intro h2,
  .contact h2 {
    max-width: 12ch;
    margin: 0.44em 0 0;
    color: #141414;
    font-size: 4.15rem;
    font-weight: 600;
    line-height: 0.92;
    letter-spacing: -0.035em;
    text-transform: none;
    text-wrap: balance;
  }

  .impact__body p {
    max-width: 33rem;
    margin: 0;
    color: #3d3d39;
    font-size: 1.28rem;
    line-height: 1.52;
  }

  .impact__body {
    grid-column: 1;
  }

  .stat-ledger {
    grid-column: 2;
    grid-row: 1 / span 2;
  }

  .stat-ledger {
    margin: 0;
    border-top: 1px solid rgba(20, 20, 20, 0.2);
  }

  .stat-ledger div {
    display: grid;
    grid-template-columns: 8.6rem 1fr;
    gap: 1.4rem;
    align-items: start;
    padding: 1.35rem 0;
    border-bottom: 1px solid rgba(20, 20, 20, 0.16);
  }

  .stat-ledger dt {
    color: #101010;
    font-size: 3.6rem;
    font-weight: 600;
    line-height: 0.9;
    letter-spacing: -0.035em;
  }

  .stat-ledger dd {
    margin: 0;
  }

  .stat-ledger span {
    display: block;
    color: var(--color-accent-text);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.045em;
    text-transform: uppercase;
  }

  .stat-ledger p,
  .ledger__row p,
  .system-ledger__row p,
  .background__row p {
    margin: 0.55rem 0 0;
    color: #4b4a46;
    font-size: 1rem;
    line-height: 1.58;
  }

  .ledger,
  .system-ledger,
  .background__rows {
    border-top: 1px solid rgba(20, 20, 20, 0.2);
  }

  .ledger__row,
  .system-ledger__row,
  .background__row {
    display: grid;
    grid-template-columns: minmax(130px, 0.34fr) minmax(240px, 0.66fr) minmax(260px, 0.86fr);
    gap: clamp(18px, 3vw, 42px);
    padding: 1.55rem 0;
    border-bottom: 1px solid rgba(20, 20, 20, 0.16);
  }

  .ledger__row span,
  .system-ledger__row span,
  .research__list span,
  .background__row span {
    color: var(--color-accent-text);
  }

  .ledger__row h3,
  .system-ledger__row h3,
  .background__row h3 {
    margin: 0;
    color: #141414;
    font-size: 1.55rem;
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.02em;
    text-transform: none;
  }

  .research__list {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid rgba(20, 20, 20, 0.2);
  }

  .research__list li {
    display: grid;
    grid-template-columns: 3.6rem 1fr;
    gap: 1rem;
    align-items: center;
    min-height: 4.55rem;
    border-bottom: 1px solid rgba(20, 20, 20, 0.16);
  }

  .research__list strong {
    color: #141414;
    font-size: 1.45rem;
    font-weight: 500;
    line-height: 1.14;
  }

  .research__list a {
    color: inherit;
    text-decoration: none;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
    transition: color 260ms var(--ease-smooth),
      text-decoration-color 260ms var(--ease-smooth);
  }

  .research__list a:hover,
  .research__list a:focus-visible {
    color: var(--color-accent-text);
    text-decoration-line: underline;
    text-decoration-color: currentColor;
    outline: none;
  }

  .contact__email {
    appearance: none;
    display: inline-block;
    margin-top: 1.6rem;
    padding: 0;
    border: 0;
    background: transparent;
    color: #141414;
    font-family: inherit;
    font-size: 2.25rem;
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.025em;
    cursor: pointer;
  }

  .contact__email:hover,
  .contact__email:focus-visible {
    color: var(--color-accent-text);
  }

  .contact__email:focus-visible {
    outline: 2px solid var(--color-accent-text);
    outline-offset: 0.2em;
  }

  [data-reveal] {
    opacity: 0.88;
    transform: translateY(16px);
    transition:
      opacity 760ms var(--ease-smooth),
      transform 760ms var(--ease-smooth);
    transition-delay: var(--delay, 0ms);
    will-change: opacity, transform;
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 1100px) {
    .home__title {
      font-size: 5rem;
    }

    .section-intro h2,
    .contact h2 {
      font-size: 3.8rem;
    }

    .impact {
      grid-template-columns: minmax(280px, 0.7fr) 1fr;
    }

    .impact__body {
      grid-column: 1;
    }

    .stat-ledger {
      grid-column: 2;
      grid-row: 1 / span 2;
    }

    .ledger__row,
    .system-ledger__row,
    .background__row {
      grid-template-columns: minmax(112px, 0.32fr) 1fr;
    }

    .ledger__row p,
    .system-ledger__row p,
    .background__row p {
      grid-column: 2;
    }
  }

  @media (max-width: 820px) {
    .home__title {
      font-size: 4.4rem;
    }

    .home__deck {
      font-size: 1.08rem;
    }

    .impact,
    .paper-section,
    .research,
    .background,
    .contact {
      grid-template-columns: 1fr;
    }

    .impact__body,
    .stat-ledger {
      grid-column: auto;
      grid-row: auto;
    }

  }

  @media (max-width: 620px) {
    .home {
      min-height: 100dvh;
      padding: calc(var(--header-h) + 112px) 22px 88px;
      align-items: start;
    }

    .home::before {
      background-size: 50vw 100%, 100% 28vh;
      opacity: 0.16;
    }

    .home::after {
      background: linear-gradient(
        90deg,
        #101010 0%,
        rgba(16, 16, 16, 0.98) 52%,
        rgba(16, 16, 16, 0.74) 76%,
        rgba(16, 16, 16, 0.18) 100%
      );
    }

    .home__inner {
      width: 100%;
      padding-left: 0;
    }

    .home__title {
      max-width: 7ch;
      font-size: 3.65rem;
    }

    .home__side-label {
      display: none;
    }

    .impact,
    .paper-section,
    .research,
    .background,
    .contact {
      width: min(100% - 32px, 1240px);
      padding-block: 68px;
    }

    .section-intro h2,
    .contact h2 {
      max-width: 11ch;
      font-size: 3rem;
    }

    .stat-ledger div,
    .ledger__row,
    .system-ledger__row,
    .background__row {
      grid-template-columns: 1fr;
      gap: 0.7rem;
      padding: 1.3rem 0;
    }

    .ledger__row p,
    .system-ledger__row p,
    .background__row p {
      grid-column: auto;
    }

    .stat-ledger dt {
      font-size: 3rem;
    }

    .research__list strong {
      font-size: 1.2rem;
    }

    .contact__email {
      font-size: 1.7rem;
      overflow-wrap: anywhere;
    }
  }

  @media (max-width: 420px) {
    .home__title {
      font-size: 3.15rem;
    }

    .section-intro h2,
    .contact h2 {
      font-size: 2.55rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(html) {
      scroll-behavior: auto;
    }

    .opening-loader {
      display: none;
    }

    .home__line > *,
    .home__title :global(.home__title-word),
    .home__deck :global(.home__deck-line),
    [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .home :global(.next-arrow) {
      opacity: 1;
    }
  }
</style>

<script>
  import { setupHomeMotion, setupListRevealMotion, setupOpeningMotion } from '../lib/legacy-motion';

  const setupHiddenEmail = () => {
    const trigger = document.querySelector<HTMLButtonElement>('[data-contact-email]');
    if (!trigger) return;

    const encoded = [
      139, 121, 114, 128, 117, 128, 127, 120, 136, 114, 127, 120, 81, 126, 118,
      133, 114, 63, 116, 128, 126,
    ];
    trigger.addEventListener('click', () => {
      const address = encoded.map((code) => String.fromCharCode(code - 17)).join('');
      window.location.href = `mailto:${address}`;
    });
  };

  setupOpeningMotion();
  setupHomeMotion();
  setupListRevealMotion('[data-reveal]');
  setupHiddenEmail();
</script>
